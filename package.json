{
  "name": "@dcyfr/ai-graphql",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready GraphQL API server template with type-safe resolvers and schema-first design",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "examples:compile": "tsc --noEmit --module nodenext --moduleResolution nodenext --target es2022 --strict --esModuleInterop true --skipLibCheck true examples/resolvers.ts",
    "examples:check": "npm run examples:compile",
    "examples:test": "npm run examples:check",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/merge": "^9.0.0",
    "@graphql-tools/schema": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-subscriptions": "^3.0.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.8",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "graphql",
    "apollo-server",
    "typescript",
    "api",
    "schema-first",
    "dcyfr"
  ],
  "author": "DCYFR Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr/dcyfr-ai-graphql"
  },
  "bugs": {
    "url": "https://github.com/dcyfr/dcyfr-ai-graphql/issues"
  },
  "homepage": "https://github.com/dcyfr/dcyfr-ai-graphql#readme"
}
